# Copy to `.env` in this folder and fill in values (do not commit `.env`).

# OpenAI (used by ai_order_extractor / conversation flow)
OPENAI_API_KEY=

# Optional: model override (default in code is typically gpt-4o-mini)
# OPENAI_ORDER_MODEL=gpt-4o-mini

# Meta WhatsApp Cloud API — from the Meta Developer App (WhatsApp product)
# Temporary token from the dashboard works for dev; production should use a System User token.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Webhook verify token — you choose this string and enter the same value in the Meta app dashboard.
WHATSAPP_VERIFY_TOKEN=

# Optional: Graph API version segment (default v21.0)
# WHATSAPP_GRAPH_API_VERSION=v21.0

# Local server (optional)
# PORT=5000
# HOST=0.0.0.0
